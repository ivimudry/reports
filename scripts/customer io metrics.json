// ── Config ──────────────────────────────────────────────────
var CIO_APP_KEY = 'API_KEY_HERE';
var CIO_BASE    = 'https://api.customer.io/v1';
var CIO_BETA    = 'https://beta-api.customer.io/v1';

// ── Custom menu ─────────────────────────────────────────────
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('CIO')
    .addItem('🔄 Refresh All Sheets', 'refreshAllSheets')
    .addItem('🔄 Refresh Active Sheet', 'refreshActiveSheet')
    .addItem('🔄 Refresh Range…', 'refreshRange')
    .addSeparator()
    .addItem('🔄 Refresh Errors', 'refreshErrors')
    .addItem('🧹 Clear Result Cache', 'clearCioResultCache')
    .addItem('🧹 Clear Cache in Range…', 'clearCioCacheInRange')
    .addToUi();
}

function clearCioResultCache() {
  var ui = SpreadsheetApp.getUi();
  var answer = ui.alert(
    'Clear CIO Result Cache',
    'This will remove saved CION/CIOC/CIONSUM/CIOCSUM values from Script Properties. Continue?',
    ui.ButtonSet.YES_NO
  );
  if (answer !== ui.Button.YES) return;

  var props = PropertiesService.getScriptProperties();
  var all = props.getProperties();
  var deleted = 0;

  for (var key in all) {
    if (key.indexOf('r_') === 0) {
      props.deleteProperty(key);
      deleted++;
    }
  }

  // Force re-fetch mode for next manual refresh run.
  CacheService.getScriptCache().put('allow_fetch', '1', 300);

  ui.alert(
    '✅ Cache cleared: ' + deleted + ' keys.\nNow run "Refresh Active Sheet" or "Refresh All Sheets" to fetch fresh values.'
  );
}

function clearCioCacheInRange() {
  var ui = SpreadsheetApp.getUi();
  var resp = ui.prompt(
    'Clear Cache in Range',
    'Enter range:\n  5:10 — rows 5-10\n  A:C — columns A-C\n  A1:G25 — specific range',
    ui.ButtonSet.OK_CANCEL
  );
  if (resp.getSelectedButton() !== ui.Button.OK) return;

  var parsed = _parseRangeInput(resp.getResponseText());
  if (!parsed) {
    ui.alert('❌ Invalid format.\n\nExamples:\n  5:10 — rows\n  A:C — columns\n  A1:G25 — range');
    return;
  }

  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();
  if (lastRow === 0 || lastCol === 0) {
    ui.alert('Sheet is empty.');
    return;
  }

  var fromRow, toRow, fromCol, toCol;
  if (parsed.type === 'rows') {
    fromRow = parsed.fromRow;
    toRow = Math.min(parsed.toRow, lastRow);
    fromCol = 1;
    toCol = lastCol;
  } else if (parsed.type === 'cols') {
    fromRow = 1;
    toRow = lastRow;
    fromCol = parsed.fromCol;
    toCol = Math.min(parsed.toCol, lastCol);
  } else {
    fromRow = parsed.fromRow;
    toRow = Math.min(parsed.toRow, lastRow);
    fromCol = parsed.fromCol;
    toCol = Math.min(parsed.toCol, lastCol);
  }

  var cells = _findCIOCells(sheet, fromRow, toRow, fromCol, toCol);
  if (cells.length === 0) {
    ui.alert('No CION/CIOC formulas found in the specified range.');
    return;
  }

  var keyMap = {};
  for (var i = 0; i < cells.length; i++) {
    var keys = _extractCacheKeysFromFormula(cells[i].formula);
    for (var k = 0; k < keys.length; k++) keyMap[keys[k]] = true;
  }

  var props = PropertiesService.getScriptProperties();
  var all = props.getProperties();
  var deleted = 0;

  for (var key in keyMap) {
    if (all.hasOwnProperty(key)) {
      props.deleteProperty(key);
      deleted++;
    }
  }

  // Also force fresh fetch for next refresh run.
  CacheService.getScriptCache().put('allow_fetch', '1', 300);

  ui.alert(
    '✅ Range cache clear complete.\n' +
    'Formulas found: ' + cells.length + '\n' +
    'Cache keys removed: ' + deleted + '\n\n' +
    'Now run a refresh to fetch fresh values.'
  );
}

function _extractCacheKeysFromFormula(formula) {
  var keys = [];
  if (!formula) return keys;

  var f = String(formula).trim();
  if (f.charAt(0) === '=') f = f.substring(1);

  var m;

  // =CIONSUM(194191) or =CIONSUM(194191; "top")
  m = f.match(/^CIONSUM\(\s*(\d+)\s*(?:[;,]\s*"?([a-zA-Z]+)"?\s*)?\)$/i);
  if (m) {
    var modeN = String(m[2] || '').toLowerCase().trim();
    keys.push(modeN === 'top' ? ('r_nsum_top_' + m[1]) : ('r_nsum_' + m[1]));
    return keys;
  }

  // =CIOCSUM(194191) or =CIOCSUM(194191; "top")
  m = f.match(/^CIOCSUM\(\s*(\d+)\s*(?:[;,]\s*"?([a-zA-Z]+)"?\s*)?\)$/i);
  if (m) {
    var modeC = String(m[2] || '').toLowerCase().trim();
    keys.push(modeC === 'top' ? ('r_csum_top_' + m[1]) : ('r_csum_' + m[1]));
    return keys;
  }

  return keys;
}

function refreshAllSheets() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var total = 0;

  for (var s = 0; s < sheets.length; s++) {
    var sheet = sheets[s];
    var lastRow = sheet.getLastRow();
    if (lastRow === 0) continue;
    var cells = _findCIOCells(sheet, 1, lastRow, 1, sheet.getLastColumn());
    if (cells.length > 0) {
      _refreshCells(sheet, cells);
      total += cells.length;
    }
  }

  SpreadsheetApp.getUi().alert(total > 0
    ? '✅ Refreshed ' + total + ' cells across ' + sheets.length + ' sheets!'
    : 'No CION/CIOC formulas found.');
}

function refreshRange() {
  var ui = SpreadsheetApp.getUi();
  var resp = ui.prompt('Refresh Range',
    'Enter range:\n  5:10 — rows 5-10\n  A:C — columns A-C\n  A1:G25 — specific range',
    ui.ButtonSet.OK_CANCEL);
  if (resp.getSelectedButton() !== ui.Button.OK) return;

  var parsed = _parseRangeInput(resp.getResponseText());
  if (!parsed) {
    ui.alert('❌ Invalid format.\n\nExamples:\n  5:10 — rows\n  A:C — columns\n  A1:G25 — range');
    return;
  }

  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();
  if (lastRow === 0 || lastCol === 0) { ui.alert('Sheet is empty.'); return; }

  var fromRow, toRow, fromCol, toCol;
  if (parsed.type === 'rows') {
    fromRow = parsed.fromRow;
    toRow   = Math.min(parsed.toRow, lastRow);
    fromCol = 1;
    toCol   = lastCol;
  } else if (parsed.type === 'cols') {
    fromRow = 1;
    toRow   = lastRow;
    fromCol = parsed.fromCol;
    toCol   = Math.min(parsed.toCol, lastCol);
  } else {
    fromRow = parsed.fromRow;
    toRow   = Math.min(parsed.toRow, lastRow);
    fromCol = parsed.fromCol;
    toCol   = Math.min(parsed.toCol, lastCol);
  }

  var cells = _findCIOCells(sheet, fromRow, toRow, fromCol, toCol);
  if (cells.length === 0) {
    ui.alert('No CION/CIOC formulas found in the specified range.');
    return;
  }

  _refreshCells(sheet, cells);
  ui.alert('✅ Refreshed ' + cells.length + ' cells!');
}

function refreshActiveSheet() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var lastRow = sheet.getLastRow();
  if (lastRow === 0) { SpreadsheetApp.getUi().alert('Sheet is empty.'); return; }

  var cells = _findCIOCells(sheet, 1, lastRow, 1, sheet.getLastColumn());

  if (cells.length === 0) {
    SpreadsheetApp.getUi().alert('No CION/CIOC formulas found on this sheet.');
    return;
  }

  _refreshCells(sheet, cells);
  SpreadsheetApp.getUi().alert('✅ Refreshed ' + cells.length + ' cells!');
}

function refreshErrors() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var total = 0;

  for (var s = 0; s < sheets.length; s++) {
    var sheet = sheets[s];
    var lastRow = sheet.getLastRow();
    var lastCol = sheet.getLastColumn();
    if (lastRow === 0 || lastCol === 0) continue;

    var data = sheet.getRange(1, 1, lastRow, lastCol).getValues();
    var formulas = sheet.getRange(1, 1, lastRow, lastCol).getFormulas();
    var cellsToRetry = [];

    for (var r = 0; r < data.length; r++) {
      for (var c = 0; c < data[r].length; c++) {
        if (!formulas[r][c]) continue;
        var val = data[r][c];
        var isRetry = typeof val === 'string' &&
          (val.indexOf('LOADING') === 0 || val === 'ERR_RETRY' || val.indexOf('ERR ') === 0);
        var isError = (val === '#ERROR!' ||
          (typeof val === 'string' && val.indexOf('Внутренняя') !== -1));
        if (isRetry || isError) {
          cellsToRetry.push({ row: r + 1, col: c + 1, formula: formulas[r][c] });
        }
      }
    }

    if (cellsToRetry.length > 0) {
      _refreshCells(sheet, cellsToRetry);
      total += cellsToRetry.length;
    }
  }

  SpreadsheetApp.getUi().alert(total > 0
    ? '✅ Refreshed ' + total + ' error cells!'
    : '✅ No errors found — all data is clean!');
}

// ── Range input parser ──────────────────────────────────────
function _parseRangeInput(input) {
  input = input.trim();
  var parts = input.split(':');
  if (parts.length !== 2) return null;

  var a = parts[0].trim();
  var b = parts[1].trim();
  if (!a || !b) return null;

  // 5:10 — row range
  if (/^\d+$/.test(a) && /^\d+$/.test(b)) {
    var fromRow = parseInt(a, 10);
    var toRow   = parseInt(b, 10);
    if (fromRow < 1 || toRow < fromRow) return null;
    return { type: 'rows', fromRow: fromRow, toRow: toRow };
  }

  // A:C — column range
  if (/^[A-Za-z]+$/.test(a) && /^[A-Za-z]+$/.test(b)) {
    var fromCol = _colToNum(a);
    var toCol   = _colToNum(b);
    if (fromCol < 1 || toCol < fromCol) return null;
    return { type: 'cols', fromCol: fromCol, toCol: toCol };
  }

  // A1:G25 — cell range
  var matchA = a.match(/^([A-Za-z]+)(\d+)$/);
  var matchB = b.match(/^([A-Za-z]+)(\d+)$/);
  if (matchA && matchB) {
    var r1 = parseInt(matchA[2], 10);
    var c1 = _colToNum(matchA[1]);
    var r2 = parseInt(matchB[2], 10);
    var c2 = _colToNum(matchB[1]);
    if (r1 < 1 || r2 < r1 || c1 < 1 || c2 < c1) return null;
    return { type: 'range', fromRow: r1, toRow: r2, fromCol: c1, toCol: c2 };
  }

  return null;
}

function _colToNum(col) {
  col = col.toUpperCase();
  var num = 0;
  for (var i = 0; i < col.length; i++) {
    num = num * 26 + (col.charCodeAt(i) - 64);
  }
  return num;
}

// ── Cell finder & refresher ─────────────────────────────────
function _findCIOCells(sheet, fromRow, toRow, fromCol, toCol) {
  var numRows = toRow - fromRow + 1;
  var numCols = toCol - fromCol + 1;
  if (numRows <= 0 || numCols <= 0) return [];

  var range = sheet.getRange(fromRow, fromCol, numRows, numCols);
  var formulas = range.getFormulas();
  var cells = [];

  for (var r = 0; r < formulas.length; r++) {
    for (var c = 0; c < formulas[r].length; c++) {
      var upper = formulas[r][c].toUpperCase();
      if (upper.indexOf('CION(') !== -1 || upper.indexOf('CIOC(') !== -1 ||
          upper.indexOf('CIONF(') !== -1 || upper.indexOf('CIOCF(') !== -1 ||
          upper.indexOf('CIONSUM(') !== -1 || upper.indexOf('CIOCSUM(') !== -1) {
        cells.push({ row: fromRow + r, col: fromCol + c, formula: formulas[r][c] });
      }
    }
  }
  return cells;
}

function _refreshCells(sheet, cells) {
  CacheService.getScriptCache().put('allow_fetch', '1', 300);
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).clearContent();
  }
  SpreadsheetApp.flush();
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).setFormula(cells[i].formula);
  }
}

// ── Persistent result cache (PropertiesService) ────────────
// Returns cached value when NOT in manual refresh mode.
// During manual refresh (allow_fetch=1), returns null to force re-fetch.
function _getCachedResult(key) {
  if (CacheService.getScriptCache().get('allow_fetch') === '1') return null;
  var raw = PropertiesService.getScriptProperties().getProperty(key);
  if (raw === null) return null;
  if (raw === '') return '';
  // Force re-fetch if cached top result contains unresolved cio_ids (no @)
  if (_isTopResult(raw) && /[0-9a-f]{16,}/.test(raw)) return null;
  var num = Number(raw);
  return (!isNaN(num) && String(num) === raw) ? num : raw;
}

// Monotonic cache: only saves if new value >= old value (for numeric metrics).
// For "top" results: compares total EUR, never loses data, prefers emails over cio_ids.
// Error/loading values are NEVER saved.
function _setCachedResult(key, value) {
  var s = String(value);
  // Never cache errors or loading states
  if (s === 'ERR_RETRY' || s.indexOf('LOADING') === 0 || s.indexOf('ERR ') === 0) return;
  try {
    var props = PropertiesService.getScriptProperties();
    var oldRaw = props.getProperty(key);

    var newNum = Number(s);
    // If new value is numeric, apply monotonic rule
    if (!isNaN(newNum) && String(newNum) === s) {
      if (oldRaw !== null && oldRaw !== '') {
        var oldNum = Number(oldRaw);
        if (!isNaN(oldNum) && newNum < oldNum) return; // never decrease
      }
      props.setProperty(key, s);
      return;
    }

    // Smart caching for "top" results (N: email — amount EUR)
    var newIsTop = _isTopResult(s);
    var newIsEmpty = (s === 'No deposit data available');
    if (newIsTop || newIsEmpty) {
      if (oldRaw !== null && oldRaw !== '') {
        var oldIsTop = _isTopResult(oldRaw);
        // Never replace real data with "no data"
        if (newIsEmpty && oldIsTop) return;
        // Compare two top results
        if (oldIsTop && newIsTop) {
          var oldTotal = _parseTopTotal(oldRaw);
          var newTotal = _parseTopTotal(s);
          // Never decrease total deposit amount
          if (newTotal < oldTotal) return;
          if (newTotal === oldTotal) {
            // Prefer version with emails over cio_ids
            var oldHasIds = /[0-9a-f]{16,}/.test(oldRaw);
            var newHasIds = /[0-9a-f]{16,}/.test(s);
            if (!oldHasIds && newHasIds) return;   // old has emails, new has ids → keep old
            if (oldRaw === s) return;               // identical → skip write
          }
        }
      }
      props.setProperty(key, s);
      return;
    }

    // Regular string values (name, date, etc.) — always overwrite
    props.setProperty(key, s);
  } catch(e) {}
}

// Checks if string looks like a top depositors result
function _isTopResult(s) {
  return s && /^\d+:\s*.+\s*[—–-]\s*[\d.]+\s*EUR$/m.test(s);
}

// Extracts total EUR from a top result string
function _parseTopTotal(s) {
  var total = 0;
  var lines = s.split('\n');
  for (var i = 0; i < lines.length; i++) {
    var m = lines[i].match(/[—–-]\s*([\d.]+)\s*EUR/);
    if (m) total += parseFloat(m[1]) || 0;
  }
  return total;
}

// ═══════════════════════════════════════════════════════════
//  CION — Newsletters (Broadcasts)
// ═══════════════════════════════════════════════════════════
/**
 * Fetches Customer.io NEWSLETTER data.
 * Metric: name | type | status | date | created | sent | delivered | opened | clicked | bounced | converted | unsubscribed | spammed | failed | attempted | suppressed | human_opened | human_clicked | prefetch_opened
 *
 * @param {number} id  Newsletter ID
 * @param {string} metric  Metric name
 * @customfunction
 */
function CION(id, metric) {
  try {
    if (!id || !metric) return '';
    return _cioFetch(id, metric, 'newsletters');
  } catch(e) {
    return _formatErr(e);
  }
}

// ═══════════════════════════════════════════════════════════
//  CIOC — Campaigns
// ═══════════════════════════════════════════════════════════
/**
 * Fetches Customer.io CAMPAIGN data.
 * Metric: name | type | status | date | created | sent | delivered | opened | clicked | bounced | converted | unsubscribed | spammed | failed | attempted | suppressed | human_opened | human_clicked | prefetch_opened
 *
 * @param {number} id  Campaign ID
 * @param {string} metric  Metric name
 * @customfunction
 */
function CIOC(id, metric) {
  try {
    if (!id || !metric) return '';
    return _cioFetch(id, metric, 'campaigns');
  } catch(e) {
    return _formatErr(e);
  }
}

// ── Shared fetch logic ──────────────────────────────────────
function _cioFetch(id, metric, type) {
  if (!id || !metric) return '';
  metric = String(metric).toLowerCase().trim();

  if (metric === 'name' || metric === 'created' || metric === 'type' || metric === 'status') {
    return _fetchInfo(id, metric, type);
  }

  if (metric === 'date') {
    return _fetchSendDate(id, type);
  }

  return _fetchMetric(id, metric, type);
}

// ── Info ────────────────────────────────────────────────────
function _fetchInfo(id, field, type) {
  var res = _apiGet('/' + type + '/' + id);
  if (res.error) return res.error;

  var c = res.data.campaign || res.data.newsletter || res.data;

  if (field === 'name')    return c.name || '';
  if (field === 'type')    return c.type || '';
  if (field === 'status') {
    if (c.state) return c.state;
    if (c.sent_at) return 'Sent';
    return 'Draft/Scheduled';
  }
  if (field === 'created') return c.created ? _tsToDate(c.created) : '';
  return '';
}

// ── Metrics ─────────────────────────────────────────────────
function _fetchMetric(id, metric, type) {
  var result = _fetchMetricsRaw(id, type);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var series = (m.series || {})[metric];
  if (!series) return 'unknown metric';

  var total = 0;
  for (var i = 0; i < series.length; i++) total += series[i];
  return total;
}

// ── Send date (first day with actual sends) ─────────────────
function _fetchSendDate(id, type) {
  var result = _fetchMetricsRaw(id, type);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var sentSeries = (m.series || {}).sent;
  if (!sentSeries) return '';

  var firstIdx = -1;
  for (var i = 0; i < sentSeries.length; i++) {
    if (sentSeries[i] > 0) { firstIdx = i; break; }
  }
  if (firstIdx === -1) return '';

  var startStr = (result.data.start || '').replace(' +0000 UTC', 'Z').replace(' ', 'T');
  var startMs  = new Date(startStr).getTime();
  var sendMs   = startMs + (firstIdx * 86400000) + (12 * 3600000);

  return Utilities.formatDate(new Date(sendMs), 'Europe/Berlin', 'dd.MM.yyyy');
}

// ── Raw metrics fetch ───────────────────────────────────────
function _fetchMetricsRaw(id, type) {
  return _apiGet('/' + type + '/' + id + '/metrics?version=2');
}

