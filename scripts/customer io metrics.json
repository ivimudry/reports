// ═══════════════════════════════════════════════════════════
//  CIONSUM — Newsletter converted deposit sum (EUR)
// ═══════════════════════════════════════════════════════════
/**
 * Calculates total deposit amount (EUR) for converted users of a NEWSLETTER.
 * Fetches only converted recipients, then takes only the FIRST deposit_made event
 * within the conversion window (converted_at -20 min → converted_at +20 min).
 *
 * @param {number} id    Newsletter ID
 * @param {string} mode  Optional: "top" — returns top 3 depositors with emails
 * @customfunction
 */
function CIONSUM(id, mode) {
  try {
    if (!id) return '';
    var m = mode ? String(mode).toLowerCase().trim() : '';
    var key = m === 'top' ? 'r_nsum_top_' + id : 'r_nsum_' + id;
    var cached = _getCachedResult(key);
    if (cached !== null) return cached;
    var result = _cioDepositSum(id, 'newsletter_id', m);
    _setCachedResult(key, result);
    return result;
  } catch(e) {
    return _formatErr(e);
  }
}

// ═══════════════════════════════════════════════════════════
//  CIOCSUM — Campaign converted deposit sum (EUR)
// ═══════════════════════════════════════════════════════════
/**
 * Calculates total deposit amount (EUR) for converted users of a CAMPAIGN.
 * Fetches only converted recipients, then takes only the FIRST deposit_made event
 * within the conversion window (converted_at -20 min → converted_at +20 min).
 *
 * @param {number} id    Campaign ID
 * @param {string} mode  Optional: "top" — returns top 3 depositors with emails
 * @customfunction
 */
function CIOCSUM(id, mode) {
  try {
    if (!id) return '';
    var m = mode ? String(mode).toLowerCase().trim() : '';
    var key = m === 'top' ? 'r_csum_top_' + id : 'r_csum_' + id;
    var cached = _getCachedResult(key);
    if (cached !== null) return cached;
    var result = _cioDepositSum(id, 'campaign_id', m);
    _setCachedResult(key, result);
    return result;
  } catch(e) {
    return _formatErr(e);
  }
}

// ═══════════════════════════════════════════════════════════
//  CIOTOPSUM — Aggregate top 3 depositors from a range
// ═══════════════════════════════════════════════════════════
/**
 * Aggregates all depositor data from a range of CIONSUM/CIOCSUM "top" results
 * and returns the overall top 3 depositors by total amount.
 *
 * @param {range} range  Range of cells containing CIONSUM(...,"top") results
 * @customfunction
 */
function CIOTOPSUM(range) {
  try {
    if (!range) return '';
    // Normalize: range can be a single value, 1D array, or 2D array
    var cells = [];
    if (Array.isArray(range)) {
      for (var r = 0; r < range.length; r++) {
        if (Array.isArray(range[r])) {
          for (var c = 0; c < range[r].length; c++) cells.push(range[r][c]);
        } else {
          cells.push(range[r]);
        }
      }
    } else {
      cells.push(range);
    }

    // Parse all "N: email — amount EUR" lines and aggregate by email
    var totals = {};
    var pattern = /^\d+:\s*(.+?)\s*[—–-]\s*([\d.]+)\s*EUR$/;

    for (var i = 0; i < cells.length; i++) {
      var val = String(cells[i] || '').trim();
      if (!val || val === 'No deposit data available') continue;
      var lines = val.split('\n');
      for (var l = 0; l < lines.length; l++) {
        var match = lines[l].trim().match(pattern);
        if (match) {
          var email = match[1].trim();
          var amount = parseFloat(match[2]);
          if (!isNaN(amount) && amount > 0) {
            totals[email] = (totals[email] || 0) + amount;
          }
        }
      }
    }

    var entries = [];
    for (var e in totals) {
      entries.push({ email: e, amount: totals[e] });
    }
    if (entries.length === 0) return 'No deposit data available';

    entries.sort(function(a, b) { return b.amount - a.amount; });
    var top = entries.slice(0, 3);
    var lines = [];
    for (var t = 0; t < top.length; t++) {
      var displayEmail = top[t].email;
      // Resolve cio_id to real email if not an email address
      if (displayEmail.indexOf('@') === -1) {
        var resolved = _getCustomerEmail(displayEmail);
        if (resolved) displayEmail = resolved;
      }
      lines.push((t + 1) + ': ' + displayEmail + ' — ' + top[t].amount + ' EUR');
    }
    return lines.join('\n');
  } catch(e) {
    return _formatErr(e);
  }
}

// ── Deposit sum logic (shared) ──────────────────────────────
function _cioDepositSum(id, filterParam, mode) {
  // 1. Get ONLY converted messages (no type filter — works for email, in_app, push)
  var convertedMsgs = [];
  var cursor = '';

  for (var page = 0; page < 50; page++) {
    var url = '/messages?' + filterParam + '=' + id + '&metric=converted&limit=100';
    if (cursor) url += '&start=' + encodeURIComponent(cursor);

    var res = _apiGet(url);
    if (res.error) return res.error;

    var msgs = res.data.messages || [];
    for (var m = 0; m < msgs.length; m++) convertedMsgs.push(msgs[m]);

    cursor = res.data.next || '';
    if (!cursor || msgs.length === 0) break;
  }

  if (convertedMsgs.length === 0) return mode === 'top' ? 'No deposit data available' : 0;

  // 2. For each converted user, fetch deposit events and take ONLY the first
  //    event within the conversion window around conversion timestamp.
  //    Window: converted_at -20 min → converted_at +20 min
  var totalAmount = 0;
  var userDeposits = {}; // email → total amount (for top mode)

  for (var i = 0; i < convertedMsgs.length; i++) {
    var msg = convertedMsgs[i];
    var cioId = (msg.customer_identifiers || {}).cio_id;
    if (!cioId) continue;

    var email = (msg.customer_identifiers || {}).email || msg.recipient || cioId;
    // Resolve cio_id to real email immediately (in-app messages have no email)
    if (email.indexOf('@') === -1) {
      var resolvedEmail = _getCustomerEmail(cioId);
      if (resolvedEmail) email = resolvedEmail;
    }
    var metrics = msg.metrics || {};
    var convertedAt = metrics.converted || 0;
    if (!convertedAt) continue;
    var windowStart = convertedAt - 1200; // -20 min
    var windowEnd   = convertedAt + 1200; // +20 min

    var userAmount = 0;
    var firstDepositTime = Infinity;
    var firstDepositAmount = 0;

    // Fetch deposit_made events from Beta API with pagination
    var evCursor = '';
    for (var p = 0; p < 10; p++) {
      var evUrl = '/customers/' + cioId + '/activities?type=event&name=deposit_made&limit=50';
      if (evCursor) evUrl += '&start=' + encodeURIComponent(evCursor);
      var evRes = _betaApiGet(evUrl);
      if (evRes.error) break;

      var activities = evRes.data.activities || [];
      if (activities.length === 0) break;

      var oldestInBatch = Infinity;
      for (var a = 0; a < activities.length; a++) {
        var ev = activities[a];
        var evTime = ev.timestamp || ev.created_at || 0;
        if (evTime < oldestInBatch) oldestInBatch = evTime;
        if (evTime >= windowStart && evTime <= windowEnd) {
          var data = ev.data || ev.attributes || {};
          var amount = parseFloat(data.human_amount_total_rounded || data.human_amount_total || data.human_amount || 0);
          if (!isNaN(amount) && evTime < firstDepositTime) {
            firstDepositTime = evTime;
            firstDepositAmount = amount;
          }
        }
      }

      // Stop if we've gone past our window (activities are newest-first)
      if (oldestInBatch < windowStart) break;

      evCursor = evRes.data.next || '';
      if (!evCursor) break;
    }

    if (firstDepositTime !== Infinity) {
      totalAmount += firstDepositAmount;
      userAmount += firstDepositAmount;
    }

    // Accumulate per-user deposits (same email may appear multiple times)
    if (mode === 'top' && userAmount > 0) {
      userDeposits[email] = (userDeposits[email] || 0) + userAmount;
    }
  }

  // Return top 3 depositors if mode=top
  if (mode === 'top') {
    var entries = [];
    for (var e in userDeposits) {
      entries.push({ email: e, amount: userDeposits[e] });
    }
    if (entries.length === 0) return 'No deposit data available';
    entries.sort(function(a, b) { return b.amount - a.amount; });
    var top = entries.slice(0, 3);
    var lines = [];
    for (var t = 0; t < top.length; t++) {
      lines.push((t + 1) + ': ' + top[t].email + ' — ' + top[t].amount + ' EUR');
    }
    return lines.join('\n');
  }

  return totalAmount;
}

// ── Customer email resolver ─────────────────────────────────
function _getCustomerEmail(cioId) {
  var res = _betaApiGet('/customers/' + cioId + '/attributes');
  if (res.error) return null;
  var attrs = res.data.customer || res.data;
  return attrs.email || attrs.attributes && attrs.attributes.email || null;
}

// ── Beta API helper ─────────────────────────────────────────
function _betaApiGet(path) {
  var res = UrlFetchApp.fetch(CIO_BETA + path, {
    headers: { 'Authorization': 'Bearer ' + CIO_APP_KEY },
    muteHttpExceptions: true
  });
  var code = res.getResponseCode();
  if (code === 401) return { error: 'ERR invalid API key' };
  if (code !== 200) return { error: 'ERR ' + code };
  return { data: JSON.parse(res.getContentText()) };
}

// ── Filtered logic ──────────────────────────────────────────
function _cioFiltered(id, metric, segmentId, filterParam) {
  if (!id || !metric || !segmentId) return '';
  metric = String(metric).toLowerCase().trim();

  // 1. Load segment members (cached)
  var members = _getSegmentMembers(segmentId);
  if (typeof members === 'string') return members;

  var memberSet = {};
  for (var i = 0; i < members.length; i++) {
    memberSet[String(members[i])] = true;
  }

  // 2. Load message recipients for this metric (cached)
  var recipients = _getMessageRecipients(id, metric, filterParam);
  if (typeof recipients === 'string') return recipients;

  // 3. Count intersection
  var count = 0;
  for (var i = 0; i < recipients.length; i++) {
    if (memberSet[recipients[i]]) count++;
  }
  return count;
}

// ── Message recipients (cached 10 min, progressive load) ────
function _getMessageRecipients(id, metric, filterParam) {
  var cacheKey = 'msg_' + filterParam + '_' + id + '_' + metric;
  var cache = CacheService.getScriptCache();

  // 1. Try complete cache
  var cached = _chunkCacheGet(cache, cacheKey);
  if (cached) return cached;

  // 2. Try resuming from partial cache (previous timeout)
  var partial = _chunkCacheGet(cache, cacheKey + '_p');
  var ids = partial || [];
  var cursor = partial ? (cache.get(cacheKey + '_cur') || '') : '';

  var startTime = new Date().getTime();

  for (var page = 0; page < 500; page++) {
    // Timeout guard: save progress, flag for auto-retry
    if (new Date().getTime() - startTime > 27000) {
      _chunkCachePut(cache, cacheKey + '_p', ids, 600);
      cache.put(cacheKey + '_cur', cursor, 600);
      return 'LOADING (' + ids.length + '…)';
    }

    var url = '/messages?' + filterParam + '=' + id + '&metric=' + metric + '&limit=1000';
    if (cursor) url += '&start=' + encodeURIComponent(cursor);

    var res = _apiGet(url);
    if (res.error) return res.error;

    var msgs = res.data.messages || [];
    for (var m = 0; m < msgs.length; m++) {
      ids.push(String(msgs[m].customer_id || msgs[m].recipient || ''));
    }

    cursor = res.data.next || '';
    if (!cursor || msgs.length === 0) break;
  }

  // Done! Cache complete result for 10 min
  _chunkCachePut(cache, cacheKey, ids, 600);
  return ids;
}

// ── Chunk cache helpers (bypass 100KB limit) ────────────────
function _chunkCachePut(cache, key, arr, ttl) {
  try {
    var json = JSON.stringify(arr);
    if (json.length < 90000) {
      cache.put(key + '_0', json, ttl);
      cache.put(key + '_n', '1', ttl);
      return;
    }
    // Split into 80KB chunks
    var chunkSize = 80000;
    var chunks = [];
    for (var i = 0; i < json.length; i += chunkSize) {
      chunks.push(json.substring(i, i + chunkSize));
    }
    if (chunks.length > 20) return; // too large
    var obj = {};
    for (var c = 0; c < chunks.length; c++) {
      obj[key + '_' + c] = chunks[c];
    }
    obj[key + '_n'] = String(chunks.length);
    cache.putAll(obj, ttl);
  } catch(e) { /* cache full */ }
}

function _chunkCacheGet(cache, key) {
  var nStr = cache.get(key + '_n');
  if (!nStr) return null;
  var n = parseInt(nStr, 10);
  if (isNaN(n) || n < 1) return null;

  var keys = [];
  for (var i = 0; i < n; i++) keys.push(key + '_' + i);
  var vals = cache.getAll(keys);

  var json = '';
  for (var i = 0; i < n; i++) {
    var v = vals[key + '_' + i];
    if (!v) return null; // chunk expired
    json += v;
  }
  try { return JSON.parse(json); } catch(e) { return null; }
}

// ── Segment membership (cached 5 min) ───────────────────────
function _getSegmentMembers(segmentId) {
  var cacheKey = 'seg_' + segmentId;
  var cache = CacheService.getScriptCache();
  var cached = cache.get(cacheKey);
  if (cached) {
    try { return JSON.parse(cached); } catch(e) { /* corrupted, re-fetch */ }
  }

  var ids = [];
  var cursor = '';

  for (var page = 0; page < 200; page++) {
    var url = '/segments/' + segmentId + '/membership';
    if (cursor) url += '?start=' + encodeURIComponent(cursor);

    var res = _apiGet(url);
    if (res.error) return res.error;

    var batch = res.data.ids || [];
    for (var i = 0; i < batch.length; i++) ids.push(batch[i]);

    cursor = res.data.next || '';
    if (!cursor || batch.length === 0) break;
  }

  // Cache for 5 minutes (CacheService max per item ~100KB)
  try {
    var json = JSON.stringify(ids);
    if (json.length < 99000) cache.put(cacheKey, json, 300);
  } catch(e) { /* too large for cache */ }

  return ids;
}

// ── Error formatter ─────────────────────────────────────────
// Wraps thrown exceptions into a readable 'ERR <msg>' string so users see
// the real cause and refreshErrors() can still detect & retry the cell.
function _formatErr(e) {
  var msg = (e && e.message) ? e.message : String(e);
  msg = msg.replace(/\s+/g, ' ').trim();
  if (msg.length > 120) msg = msg.substring(0, 117) + '...';
  return 'ERR ' + msg;
}

// ── HTTP helper ─────────────────────────────────────────────
function _apiGet(path) {
  var res = UrlFetchApp.fetch(CIO_BASE + path, {
    headers: { 'Authorization': 'Bearer ' + CIO_APP_KEY },
    muteHttpExceptions: true
  });
  var code = res.getResponseCode();
  if (code === 401) return { error: 'ERR invalid API key' };
  if (code === 301) return { error: 'ERR wrong datacenter' };
  if (code !== 200) return { error: 'ERR ' + code + ' (ID not found)' };
  return { data: JSON.parse(res.getContentText()) };
}

function _tsToDate(unix) {
  return Utilities.formatDate(new Date(unix * 1000), 'Europe/Berlin', 'dd.MM.yyyy');
}
