// ── Config ──────────────────────────────────────────────────
var CIO_APP_KEY = 'API_KEY_HERE';
var CIO_BASE    = 'https://api.customer.io/v1';

// ── Custom menu ─────────────────────────────────────────────
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('CIO')
    .addItem('🔄 Refresh All Data', 'refreshAllCIO')
    .addItem('🔄 Refresh Row Range...', 'refreshRangeCIO')
    .addToUi();
}

function refreshAllCIO() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var cells = _findCIOCells(sheet, 1, sheet.getLastRow());

  if (cells.length === 0) {
    SpreadsheetApp.getUi().alert('No CIO() formulas found.');
    return;
  }

  _refreshCells(sheet, cells);
  SpreadsheetApp.getUi().alert('✅ Refreshed ' + cells.length + ' cells!');
}

function refreshRangeCIO() {
  var ui = SpreadsheetApp.getUi();

  var resp = ui.prompt('Refresh Row Range', 'Enter range (e.g. 5-30):', ui.ButtonSet.OK_CANCEL);
  if (resp.getSelectedButton() !== ui.Button.OK) return;

  var parts = resp.getResponseText().split('-');
  var fromRow = parseInt(parts[0], 10);
  var toRow   = parseInt(parts[1], 10);

  if (parts.length !== 2 || isNaN(fromRow) || isNaN(toRow) || fromRow < 1 || toRow < fromRow) {
    ui.alert('❌ Invalid format. Use "from-to", e.g. 5-30');
    return;
  }

  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var cells = _findCIOCells(sheet, fromRow, toRow);

  if (cells.length === 0) {
    ui.alert('No CIO() formulas found in rows ' + fromRow + '-' + toRow + '.');
    return;
  }

  _refreshCells(sheet, cells);
  ui.alert('✅ Refreshed ' + cells.length + ' cells (rows ' + fromRow + '-' + toRow + ')!');
}

function _findCIOCells(sheet, fromRow, toRow) {
  var lastCol = sheet.getLastColumn();
  if (lastCol === 0) return [];
  var numRows = toRow - fromRow + 1;
  var range = sheet.getRange(fromRow, 1, numRows, lastCol);
  var formulas = range.getFormulas();
  var cells = [];

  for (var r = 0; r < formulas.length; r++) {
    for (var c = 0; c < formulas[r].length; c++) {
      if (formulas[r][c].toUpperCase().indexOf('CIO(') !== -1) {
        cells.push({ row: fromRow + r, col: c + 1, formula: formulas[r][c] });
      }
    }
  }
  return cells;
}

function _refreshCells(sheet, cells) {
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).clearContent();
  }
  SpreadsheetApp.flush();
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).setFormula(cells[i].formula);
  }
}

// ── Main function ───────────────────────────────────────────
/**
 * Fetches Customer.io newsletter data. Metric: "name" | "type" | "status" | "date" | "created" | "sent" | "delivered" | "opened" | "clicked" | "bounced" | "converted" | "unsubscribed" | "spammed" | "failed" | "attempted" | "suppressed" | "human_opened" | "human_clicked" | "prefetch_opened"
 *
 * @param {number} campaignId  Newsletter ID
 * @param {string} metric      Metric name
 * @customfunction
 */
function CIO(campaignId, metric) {
  if (!campaignId || !metric) return '';
  metric = String(metric).toLowerCase().trim();

  if (metric === 'name' || metric === 'created' || metric === 'type' || metric === 'status') {
    return _fetchInfo(campaignId, metric);
  }

  if (metric === 'date') {
    return _fetchSendDate(campaignId);
  }

  return _fetchMetric(campaignId, metric);
}

// ── Metrics ─────────────────────────────────────────────────
function _fetchMetric(campaignId, metric) {
  var result = _fetchMetricsRaw(campaignId);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var series = (m.series || {})[metric];
  if (!series) return 'unknown metric';

  var total = 0;
  for (var i = 0; i < series.length; i++) total += series[i];
  return total;
}

// ── Send date (first day with actual sends) ─────────────────
function _fetchSendDate(campaignId) {
  var result = _fetchMetricsRaw(campaignId);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var sentSeries = (m.series || {}).sent;
  if (!sentSeries) return '';

  var firstIdx = -1;
  for (var i = 0; i < sentSeries.length; i++) {
    if (sentSeries[i] > 0) { firstIdx = i; break; }
  }
  if (firstIdx === -1) return '';

  var startStr = (result.data.start || '').replace(' +0000 UTC', 'Z').replace(' ', 'T');
  var startMs  = new Date(startStr).getTime();
  var dayMs    = 86400000;
  var sendMs   = startMs + (firstIdx * dayMs) + (12 * 3600000);

  return Utilities.formatDate(new Date(sendMs), 'Europe/Berlin', 'dd.MM.yyyy');
}

// ── Campaign/Newsletter info ────────────────────────────────
function _fetchInfo(campaignId, field) {
  var endpoints = [
    '/campaigns/' + campaignId,
    '/newsletters/' + campaignId
  ];

  for (var e = 0; e < endpoints.length; e++) {
    var res = UrlFetchApp.fetch(CIO_BASE + endpoints[e], {
      headers: { 'Authorization': 'Bearer ' + CIO_APP_KEY },
      muteHttpExceptions: true
    });
    var code = res.getResponseCode();
    if (code === 401) return 'ERR invalid API key';
    if (code === 301) return 'ERR wrong datacenter';
    if (code === 200) {
      var json = JSON.parse(res.getContentText());
      var c = json.campaign || json.newsletter || json;

      if (field === 'name')    return c.name || '';
      if (field === 'type')    return c.type || '';
      if (field === 'status') {
        if (c.sent_at) return 'Sent/Sending';
        return 'Draft/Scheduled';
      }
      if (field === 'created') return c.created ? _tsToDate(c.created) : '';
      return '';
    }
  }

  return 'ERR not found (ID: ' + campaignId + ')';
}

// ── Raw metrics fetch (shared) ──────────────────────────────
function _fetchMetricsRaw(campaignId) {
  var endpoints = [
    '/campaigns/' + campaignId + '/metrics?version=2',
    '/newsletters/' + campaignId + '/metrics?version=2'
  ];

  for (var e = 0; e < endpoints.length; e++) {
    var res = UrlFetchApp.fetch(CIO_BASE + endpoints[e], {
      headers: { 'Authorization': 'Bearer ' + CIO_APP_KEY },
      muteHttpExceptions: true
    });
    var code = res.getResponseCode();
    if (code === 401) return { error: 'ERR invalid API key' };
    if (code === 301) return { error: 'ERR wrong datacenter' };
    if (code === 200) {
      return { data: JSON.parse(res.getContentText()) };
    }
  }

  return { error: 'ERR not found (ID: ' + campaignId + ')' };
}

function _tsToDate(unix) {
  var d = new Date(unix * 1000);
  return Utilities.formatDate(d, 'Europe/Berlin', 'dd.MM.yyyy');
}
