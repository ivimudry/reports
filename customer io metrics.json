// ── Config ──────────────────────────────────────────────────
var CIO_APP_KEY = 'API_KEY_HERE';
var CIO_BASE    = 'https://api.customer.io/v1';

// ── Custom menu ─────────────────────────────────────────────
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('CIO')
    .addItem('🔄 Refresh All Data', 'refreshAllCIO')
    .addItem('🔄 Refresh Row Range…', 'refreshRangeCIO')
    .addToUi();
}

function refreshAllCIO() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var cells = _findCIOCells(sheet, 1, sheet.getLastRow());

  if (cells.length === 0) {
    SpreadsheetApp.getUi().alert('No CION/CIOC formulas found.');
    return;
  }

  _refreshCells(sheet, cells);
  SpreadsheetApp.getUi().alert('✅ Refreshed ' + cells.length + ' cells!');
}

function refreshRangeCIO() {
  var ui = SpreadsheetApp.getUi();

  var resp = ui.prompt('Refresh Row Range', 'Enter range (e.g. 5-30):', ui.ButtonSet.OK_CANCEL);
  if (resp.getSelectedButton() !== ui.Button.OK) return;

  var parts = resp.getResponseText().split('-');
  var fromRow = parseInt(parts[0], 10);
  var toRow   = parseInt(parts[1], 10);

  if (parts.length !== 2 || isNaN(fromRow) || isNaN(toRow) || fromRow < 1 || toRow < fromRow) {
    ui.alert('❌ Invalid format. Use "from-to", e.g. 5-30');
    return;
  }

  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var cells = _findCIOCells(sheet, fromRow, toRow);

  if (cells.length === 0) {
    ui.alert('No CION/CIOC formulas found in rows ' + fromRow + '-' + toRow + '.');
    return;
  }

  _refreshCells(sheet, cells);
  ui.alert('✅ Refreshed ' + cells.length + ' cells (rows ' + fromRow + '-' + toRow + ')!');
}

function _findCIOCells(sheet, fromRow, toRow) {
  var lastCol = sheet.getLastColumn();
  if (lastCol === 0) return [];
  var numRows = toRow - fromRow + 1;
  var range = sheet.getRange(fromRow, 1, numRows, lastCol);
  var formulas = range.getFormulas();
  var cells = [];

  for (var r = 0; r < formulas.length; r++) {
    for (var c = 0; c < formulas[r].length; c++) {
      var upper = formulas[r][c].toUpperCase();
      if (upper.indexOf('CION(') !== -1 || upper.indexOf('CIOC(') !== -1 ||
          upper.indexOf('CIONF(') !== -1 || upper.indexOf('CIOCF(') !== -1) {
        cells.push({ row: fromRow + r, col: c + 1, formula: formulas[r][c] });
      }
    }
  }
  return cells;
}

function _refreshCells(sheet, cells) {
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).clearContent();
  }
  SpreadsheetApp.flush();
  for (var i = 0; i < cells.length; i++) {
    sheet.getRange(cells[i].row, cells[i].col).setFormula(cells[i].formula);
  }
}

// ═══════════════════════════════════════════════════════════
//  CION — Newsletters (Broadcasts)
// ═══════════════════════════════════════════════════════════
/**
 * Fetches Customer.io NEWSLETTER data.
 * Metric: name | type | status | date | created | sent | delivered | opened | clicked | bounced | converted | unsubscribed | spammed | failed | attempted | suppressed | human_opened | human_clicked | prefetch_opened
 *
 * @param {number} id  Newsletter ID
 * @param {string} metric  Metric name
 * @customfunction
 */
function CION(id, metric) {
  return _cioFetch(id, metric, 'newsletters');
}

// ═══════════════════════════════════════════════════════════
//  CIOC — Campaigns
// ═══════════════════════════════════════════════════════════
/**
 * Fetches Customer.io CAMPAIGN data.
 * Metric: name | type | status | date | created | sent | delivered | opened | clicked | bounced | converted | unsubscribed | spammed | failed | attempted | suppressed | human_opened | human_clicked | prefetch_opened
 *
 * @param {number} id  Campaign ID
 * @param {string} metric  Metric name
 * @customfunction
 */
function CIOC(id, metric) {
  return _cioFetch(id, metric, 'campaigns');
}

// ── Shared fetch logic ──────────────────────────────────────
function _cioFetch(id, metric, type) {
  if (!id || !metric) return '';
  metric = String(metric).toLowerCase().trim();

  if (metric === 'name' || metric === 'created' || metric === 'type' || metric === 'status') {
    return _fetchInfo(id, metric, type);
  }

  if (metric === 'date') {
    return _fetchSendDate(id, type);
  }

  return _fetchMetric(id, metric, type);
}

// ── Info ────────────────────────────────────────────────────
function _fetchInfo(id, field, type) {
  var res = _apiGet('/' + type + '/' + id);
  if (res.error) return res.error;

  var c = res.data.campaign || res.data.newsletter || res.data;

  if (field === 'name')    return c.name || '';
  if (field === 'type')    return c.type || '';
  if (field === 'status') {
    if (c.state) return c.state;
    if (c.sent_at) return 'Sent';
    return 'Draft/Scheduled';
  }
  if (field === 'created') return c.created ? _tsToDate(c.created) : '';
  return '';
}

// ── Metrics ─────────────────────────────────────────────────
function _fetchMetric(id, metric, type) {
  var result = _fetchMetricsRaw(id, type);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var series = (m.series || {})[metric];
  if (!series) return 'unknown metric';

  var total = 0;
  for (var i = 0; i < series.length; i++) total += series[i];
  return total;
}

// ── Send date (first day with actual sends) ─────────────────
function _fetchSendDate(id, type) {
  var result = _fetchMetricsRaw(id, type);
  if (result.error) return result.error;

  var m = result.data.metric || result.data;
  var sentSeries = (m.series || {}).sent;
  if (!sentSeries) return '';

  var firstIdx = -1;
  for (var i = 0; i < sentSeries.length; i++) {
    if (sentSeries[i] > 0) { firstIdx = i; break; }
  }
  if (firstIdx === -1) return '';

  var startStr = (result.data.start || '').replace(' +0000 UTC', 'Z').replace(' ', 'T');
  var startMs  = new Date(startStr).getTime();
  var sendMs   = startMs + (firstIdx * 86400000) + (12 * 3600000);

  return Utilities.formatDate(new Date(sendMs), 'Europe/Berlin', 'dd.MM.yyyy');
}

// ── Raw metrics fetch ───────────────────────────────────────
function _fetchMetricsRaw(id, type) {
  return _apiGet('/' + type + '/' + id + '/metrics?version=2');
}

// ═══════════════════════════════════════════════════════════
//  CIONF — Newsletter metric filtered by segment
// ═══════════════════════════════════════════════════════════
/**
 * Newsletter metric filtered by segment.
 * Returns count of people who received/opened/clicked the newsletter AND are in the segment.
 *
 * @param {number} id         Newsletter ID
 * @param {string} metric     sent | delivered | opened | clicked | bounced | unsubscribed | spammed
 * @param {number} segmentId  Segment ID to filter by
 * @customfunction
 */
function CIONF(id, metric, segmentId) {
  return _cioFiltered(id, metric, segmentId, 'newsletter_id');
}

// ═══════════════════════════════════════════════════════════
//  CIOCF — Campaign metric filtered by segment
// ═══════════════════════════════════════════════════════════
/**
 * Campaign metric filtered by segment.
 * Returns count of people who received/opened/clicked the campaign AND are in the segment.
 *
 * @param {number} id         Campaign ID
 * @param {string} metric     sent | delivered | opened | clicked | bounced | unsubscribed | spammed
 * @param {number} segmentId  Segment ID to filter by
 * @customfunction
 */
function CIOCF(id, metric, segmentId) {
  return _cioFiltered(id, metric, segmentId, 'campaign_id');
}

// ── Filtered logic ──────────────────────────────────────────
function _cioFiltered(id, metric, segmentId, filterParam) {
  if (!id || !metric || !segmentId) return '';
  metric = String(metric).toLowerCase().trim();

  // 1. Load segment members (cached)
  var members = _getSegmentMembers(segmentId);
  if (typeof members === 'string') return members;

  var memberSet = {};
  for (var i = 0; i < members.length; i++) {
    memberSet[String(members[i])] = true;
  }

  // 2. Load message recipients for this metric (cached)
  var recipients = _getMessageRecipients(id, metric, filterParam);
  if (typeof recipients === 'string') return recipients;

  // 3. Count intersection
  var count = 0;
  for (var i = 0; i < recipients.length; i++) {
    if (memberSet[recipients[i]]) count++;
  }
  return count;
}

// ── Message recipients (cached 10 min) ──────────────────────
function _getMessageRecipients(id, metric, filterParam) {
  var cacheKey = 'msg_' + filterParam + '_' + id + '_' + metric;
  var cache = CacheService.getScriptCache();

  // Try chunk-cache: msg_..._0, msg_..._1, ...
  var cached = _chunkCacheGet(cache, cacheKey);
  if (cached) return cached;

  var startTime = new Date().getTime();
  var ids = [];
  var cursor = '';

  for (var page = 0; page < 500; page++) {
    // Timeout guard: stop at 20 sec to leave room
    if (new Date().getTime() - startTime > 20000) {
      return 'TIMEOUT (' + ids.length + ' processed)';
    }

    var url = '/messages?' + filterParam + '=' + id + '&metric=' + metric + '&type=email&limit=1000';
    if (cursor) url += '&start=' + encodeURIComponent(cursor);

    var res = _apiGet(url);
    if (res.error) return res.error;

    var msgs = res.data.messages || [];
    for (var m = 0; m < msgs.length; m++) {
      ids.push(String(msgs[m].customer_id || msgs[m].recipient || ''));
    }

    cursor = res.data.next || '';
    if (!cursor || msgs.length === 0) break;
  }

  // Cache for 10 minutes (chunk if large)
  _chunkCachePut(cache, cacheKey, ids, 600);
  return ids;
}

// ── Chunk cache helpers (bypass 100KB limit) ────────────────
function _chunkCachePut(cache, key, arr, ttl) {
  try {
    var json = JSON.stringify(arr);
    if (json.length < 90000) {
      cache.put(key + '_0', json, ttl);
      cache.put(key + '_n', '1', ttl);
      return;
    }
    // Split into 80KB chunks
    var chunkSize = 80000;
    var chunks = [];
    for (var i = 0; i < json.length; i += chunkSize) {
      chunks.push(json.substring(i, i + chunkSize));
    }
    if (chunks.length > 20) return; // too large
    var obj = {};
    for (var c = 0; c < chunks.length; c++) {
      obj[key + '_' + c] = chunks[c];
    }
    obj[key + '_n'] = String(chunks.length);
    cache.putAll(obj, ttl);
  } catch(e) { /* cache full */ }
}

function _chunkCacheGet(cache, key) {
  var nStr = cache.get(key + '_n');
  if (!nStr) return null;
  var n = parseInt(nStr, 10);
  if (isNaN(n) || n < 1) return null;

  var keys = [];
  for (var i = 0; i < n; i++) keys.push(key + '_' + i);
  var vals = cache.getAll(keys);

  var json = '';
  for (var i = 0; i < n; i++) {
    var v = vals[key + '_' + i];
    if (!v) return null; // chunk expired
    json += v;
  }
  try { return JSON.parse(json); } catch(e) { return null; }
}

// ── Segment membership (cached 5 min) ───────────────────────
function _getSegmentMembers(segmentId) {
  var cacheKey = 'seg_' + segmentId;
  var cache = CacheService.getScriptCache();
  var cached = cache.get(cacheKey);
  if (cached) {
    try { return JSON.parse(cached); } catch(e) { /* corrupted, re-fetch */ }
  }

  var ids = [];
  var cursor = '';

  for (var page = 0; page < 200; page++) {
    var url = '/segments/' + segmentId + '/membership';
    if (cursor) url += '?start=' + encodeURIComponent(cursor);

    var res = _apiGet(url);
    if (res.error) return res.error;

    var batch = res.data.ids || [];
    for (var i = 0; i < batch.length; i++) ids.push(batch[i]);

    cursor = res.data.next || '';
    if (!cursor || batch.length === 0) break;
  }

  // Cache for 5 minutes (CacheService max per item ~100KB)
  try {
    var json = JSON.stringify(ids);
    if (json.length < 99000) cache.put(cacheKey, json, 300);
  } catch(e) { /* too large for cache */ }

  return ids;
}

// ── HTTP helper ─────────────────────────────────────────────
function _apiGet(path) {
  var res = UrlFetchApp.fetch(CIO_BASE + path, {
    headers: { 'Authorization': 'Bearer ' + CIO_APP_KEY },
    muteHttpExceptions: true
  });
  var code = res.getResponseCode();
  if (code === 401) return { error: 'ERR invalid API key' };
  if (code === 301) return { error: 'ERR wrong datacenter' };
  if (code !== 200) return { error: 'ERR ' + code + ' (ID not found)' };
  return { data: JSON.parse(res.getContentText()) };
}

function _tsToDate(unix) {
  return Utilities.formatDate(new Date(unix * 1000), 'Europe/Berlin', 'dd.MM.yyyy');
}
